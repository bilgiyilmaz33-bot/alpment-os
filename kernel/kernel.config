# Alpment OS 0.1 - Kernel Configuration
# Linux Kernel 6.x için optimize edilmiş yapılandırma

# Genel Ayarlar
CONFIG_KERNEL_LZ4=y
CONFIG_KERNEL_ZSTD=y
CONFIG_HAVE_KERNEL_GZIP=y
CONFIG_HAVE_KERNEL_BZIP2=y

# Dosya Sistemleri
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_BTRFS_FS=m
CONFIG_XFS_FS=m
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_LZ4=y

# Önyükleme
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_X86_BOOT=y
CONFIG_X86_BIOS=y

# Ağ
CONFIG_NET=y
CONFIG_INET=y
CONFIG_NETDEVICES=y
CONFIG_NET_ETHERNET=y
CONFIG_WIRELESS=y
CONFIG_CFG80211=y

# USB Desteği
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_HID=y

# Ses Sistemi
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_HDA_INTEL=y

# Grafik
CONFIG_AGP=y
CONFIG_DRM=y
CONFIG_DRM_I915=m
CONFIG_DRM_AMDGPU=m
CONFIG_DRM_NOUVEAU=m

# Giriş Cihazları
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_INPUT_TOUCHPAD=y

# Güvenlik
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=n
CONFIG_SECURITY_APPARMOR=y
CONFIG_HAVE_HARDENED_USERCOPY=y

# Performance
CONFIG_SCHED_DEBUG=n
CONFIG_DEBUG_KERNEL=n
CONFIG_SLUB_DEBUG=n
CONFIG_SLUB_DEBUG_ON=n

# Sıkıştırma
CONFIG_HAVE_EFFICIENT_UNALIGNED_ACCESS=y
CONFIG_ARCH_USE_CMPXCHG_LOCKREF=y
